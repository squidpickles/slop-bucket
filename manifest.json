{
  "manifest_version": 3,
  "name": "Slop Bucket",
  "version": "0.1.0",
  "description": "Mark a site as (AI) slop and treat it with the respect it deserves on the next visit.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "slop-bucket@sweetpea",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Slop Bucket",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["slop-page/slop.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
